---
import partners from "../data/partners.json";
const items = partners.items || [];
// repeat the set enough times so the row always fills wide screens with no gaps
const SETS = 3;
const loop = Array.from({ length: SETS }, () => items).flat();
---
{items.length > 0 && (
  <section class="partners">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow">השותפים שלנו</span>
        <h2>{partners.title}</h2>
      </div>
    </div>
    <div class="marquee">
      <div class="marquee-track" style={`--marquee-sets:${SETS}`}>
        {loop.map((p) => (
          <div class="logo-cell"><img src={p.logo} alt={p.name}/></div>
        ))}
      </div>
    </div>
  </section>
)}
