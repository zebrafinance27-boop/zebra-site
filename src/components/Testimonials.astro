---
import { getCollection } from "astro:content";
const approved = await getCollection("testimonials", ({ data }) => data.approved);
const sorted = approved.sort(
  (a, b) => (b.data.date?.valueOf() || 0) - (a.data.date?.valueOf() || 0)
);
const items = await Promise.all(
  sorted.slice(0, 6).map(async (t) => ({ data: t.data, Content: (await t.render()).Content }))
);
---
{items.length > 0 && (
  <section class="block">
    <div class="wrap">
      <div class="sec-head center reveal">
        <span class="eyebrow">לקוחות מספרים</span>
        <h2>אנשים שכבר קיבלו מענה</h2>
      </div>
      <div class="quotes">
        {items.map(({ data, Content }) => (
          <div class="quote reveal">
            <div class="stars">{"★".repeat(data.rating)}{"☆".repeat(5 - data.rating)}</div>
            <div class="q-body"><Content /></div>
            <div class="who">{data.name}{data.city && <span>{data.city}</span>}</div>
          </div>
        ))}
      </div>
      <div class="center" style="margin-top:30px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn" href="/testimonial/">כתבו לנו המלצה</a>
        <a class="btn btn-line" href="/reviews/">לכל ההמלצות</a>
      </div>
    </div>
  </section>
)}
